{
  "name": "raffle",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "test": "turbo test",
    "db:migrate": "npm -w packages/server run db:migrate",
    "db:seed": "npm -w packages/server run db:seed",
    "db:studio": "npm -w packages/server run db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
