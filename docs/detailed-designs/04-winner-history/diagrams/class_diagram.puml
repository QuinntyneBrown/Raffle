@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 12

title Winner History - Data Model

class ActiveRafflePublic {
    +id: String
    +heading: String
    +theme: Theme
    +animationStyle: AnimationStyle
    +participantNames: List<String>
    +allDrawn: Boolean
    +lastDrawnName: String
    +drawnNames: List<String> **new**
}

class WinnerHistoryProps {
    +drawnNames: List<String>
}

class Participant {
    +id: String
    +raffleId: String
    +name: String
    +isDrawn: Boolean
    +drawOrder: Integer
}

ActiveRafflePublic ..> WinnerHistoryProps : "passes drawnNames"
Participant "0..*" --> ActiveRafflePublic : "derived from drawn participants"

@enduml
